        <mxCell id="msg5" value="Generate Response (Context + Prompt)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fontFamily=Inter;strokeColor=#059669;" edge="1" parent="1" source="ll3" target="ll5">
