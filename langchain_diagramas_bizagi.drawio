  <diagram name="3. Classes" id="2">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title3" value="Diagrama de Classes - Arquitetura LangChain &amp; Evaluation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="750" height="40" as="geometry" />
        </mxCell>
        <!-- Classes -->
        <mxCell id="c_agent" value="BaseAgent&#xa;--&#xa;- llm: ChatOpenAI&#xa;- tools: List[Tool]&#xa;- memory: MemoryBuffer&#xa;--&#xa;+ invoke(query: str): dict&#xa;+ setup_prompt(): PromptTemplate" style="shape=module;align=left;spacingLeft=10;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fillColor=#F8FAFC;strokeColor=#4B5563;fontFamily=Inter;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="c_orchestrator" value="OrchestratorAgent&#xa;--&#xa;- agents: Dict[str, BaseAgent]&#xa;- router: RouteLLM&#xa;--&#xa;+ route_query(query: str)&#xa;+ synthesize_response()" style="shape=module;align=left;spacingLeft=10;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fillColor=#F8FAFC;strokeColor=#4B5563;fontFamily=Inter;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="150" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="c_rag" value="RAGPipeline&#xa;--&#xa;- vector_store: FAISS&#xa;- embeddings: Embeddings&#xa;- retriever: BaseRetriever&#xa;--&#xa;+ index_documents()&#xa;+ retrieve(query: str)" style="shape=module;align=left;spacingLeft=10;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fillColor=#F8FAFC;strokeColor=#4B5563;fontFamily=Inter;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="c_eval" value="EvaluationRunner&#xa;--&#xa;- judge_llm: ChatOpenAI&#xa;- metrics: List[str]&#xa;--&#xa;+ evaluate_coherence()&#xa;+ assert_patterns()" style="shape=module;align=left;spacingLeft=10;verticalAlign=top;whiteSpace=wrap;html=1;rounded=1;fillColor=#F8FAFC;strokeColor=#4B5563;fontFamily=Inter;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="150" width="220" height="150" as="geometry" />
        </mxCell>
        <!-- Lines / Inheritance -->
        <mxCell id="c_rel1" value="&lt;&lt;uses&gt;&gt;" style="endArrow=open;endSize=10;endFill=0;html=1;rounded=0;fontFamily=Inter;strokeColor=#4B5563;dashed=1;" edge="1" parent="1" source="c_orchestrator" target="c_agent">
          <mxGeometry width="160" relative="1" as="geometry">
            <mxPoint as="sourcePoint" />
            <mxPoint as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="c_rel2" value="&lt;&lt;consumes&gt;&gt;" style="endArrow=open;endSize=10;endFill=0;html=1;rounded=0;fontFamily=Inter;strokeColor=#4B5563;dashed=1;" edge="1" parent="1" source="c_agent" target="c_rag">
          <mxGeometry width="160" relative="1" as="geometry">
            <mxPoint as="sourcePoint" />
            <mxPoint as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="c_rel3" value="&lt;&lt;evaluates&gt;&gt;" style="endArrow=open;endSize=10;endFill=0;html=1;rounded=0;fontFamily=Inter;strokeColor=#4B5563;dashed=1;" edge="1" parent="1" source="c_eval" target="c_orchestrator">
          <mxGeometry width="160" relative="1" as="geometry">
            <mxPoint as="sourcePoint" />
            <mxPoint as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="4. BPMN" id="3">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
